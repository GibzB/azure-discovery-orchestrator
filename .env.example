# Azure OpenAI (AIServices account — use when Azure for Students OpenAI quota is unavailable)
# AIServices endpoint format: https://<name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT=gpt-oss-120b
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure Speech (speech-to-speech pipeline)
AZURE_SPEECH_KEY=<your-key>
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_VOICE=en-US-AvaMultilingualNeural

# Azure AI Search
SEARCH_ENDPOINT=https://<your-resource>.search.windows.net
SEARCH_KEY=<your-key>
SEARCH_INDEX=knowledgebase

# Cosmos DB
COSMOS_ENDPOINT=https://<your-resource>.documents.azure.com:443/
COSMOS_KEY=<your-key>
COSMOS_DATABASE=discovery
COSMOS_CONTAINER=sessions

# App
CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO

# MCP Servers (no keys needed — Learn MCP is public, Azure MCP uses Azure CLI credential chain)
# Microsoft Learn MCP: https://learn.microsoft.com/api/mcp  (auto-configured)
# Azure MCP: npx @azure/mcp@latest server start             (requires Node.js + az login)
